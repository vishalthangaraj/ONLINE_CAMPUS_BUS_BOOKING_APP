<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Campus Bus Booking</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
      padding: 20px;
    }

    .container {
      max-width: 900px;
      margin: 0 auto;
      background: white;
      border-radius: 10px;
      padding: 30px;
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
    }

    /* ===== LOGIN PAGE STYLES ===== */
    .login-section {
      display: block;
    }

    .login-section.hidden {
      display: none;
    }

    .brand {
      text-align: center;
      margin-bottom: 30px;
    }

    .logo {
      width: 70px;
      height: 70px;
      background: linear-gradient(135deg, #667eea, #764ba2);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-size: 32px;
      font-weight: bold;
      margin: 0 auto 15px;
    }

    .brand h1 {
      color: #333;
      margin-bottom: 5px;
      font-size: 28px;
    }

    .muted {
      color: #666;
      font-size: 14px;
      margin-bottom: 20px;
      text-align: center;
    }

    .card {
      max-width: 400px;
      margin: 0 auto;
    }

    form {
      margin-bottom: 20px;
    }

    label {
      display: block;
      margin-bottom: 5px;
      font-weight: 600;
      color: #333;
      font-size: 14px;
    }

    input {
      width: 100%;
      padding: 12px;
      margin-bottom: 15px;
      border: 1px solid #ddd;
      border-radius: 8px;
      font-size: 14px;
      transition: border-color 0.3s ease;
    }

    input:focus {
      outline: none;
      border-color: #667eea;
    }

    .btn {
      padding: 12px 30px;
      border: none;
      border-radius: 8px;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .btn.primary {
      width: 100%;
      background: #667eea;
      color: white;
      margin-bottom: 15px;
    }

    .btn.primary:hover {
      background: #5568d3;
      box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
    }

    .btn.google {
      width: 100%;
      background: #4285f4;
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
    }

    .btn.google:hover {
      background: #1f5dcf;
    }

    .divider {
      text-align: center;
      margin: 20px 0;
      position: relative;
    }

    .divider span {
      background: white;
      padding: 0 10px;
      color: #999;
      font-size: 14px;
    }

    .divider::before {
      content: '';
      position: absolute;
      top: 50%;
      left: 0;
      right: 0;
      height: 1px;
      background: #ddd;
      z-index: -1;
    }

    .small {
      font-size: 12px;
      text-align: center;
    }

    .small a {
      color: #667eea;
      text-decoration: none;
    }

    /* ===== BUS BOOKING PAGE STYLES ===== */
    .bus-section {
      display: none;
    }

    .bus-section.active {
      display: block;
    }

    .header {
      text-align: center;
      margin-bottom: 30px;
    }

    .header h1 {
      color: #333;
      margin-bottom: 10px;
      font-size: 28px;
    }

    .user-info {
      color: #666;
      font-size: 14px;
      margin-bottom: 20px;
      display: flex;
      justify-content: center;
      gap: 15px;
      align-items: center;
    }

    .bus-info {
      background: #f5f5f5;
      padding: 15px;
      border-radius: 8px;
      margin-bottom: 30px;
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 15px;
      text-align: center;
    }

    .bus-info div {
      padding: 10px;
    }

    .bus-info label {
      display: block;
      font-size: 12px;
      color: #999;
      margin-bottom: 5px;
      font-weight: 600;
    }

    .bus-info span {
      display: block;
      font-size: 18px;
      color: #333;
      font-weight: bold;
    }

    .seating-layout {
      margin: 30px 0;
      padding: 20px;
      background: #fafafa;
      border-radius: 8px;
      text-align: center;
    }

    .seating-layout h3 {
      margin-bottom: 20px;
      color: #333;
      font-size: 18px;
    }

    .bus-seats {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
      justify-content: center;
      max-width: 400px;
      margin: 0 auto;
    }

    .seat {
      width: 60px;
      height: 60px;
      border: 2px solid #ddd;
      border-radius: 8px;
      cursor: pointer;
      font-size: 12px;
      font-weight: bold;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.3s ease;
      background: #fff;
      color: #333;
    }

    .seat:hover:not(.booked) {
      border-color: #667eea;
      background: #f0f0ff;
      transform: scale(1.05);
    }

    .seat.selected {
      background: #667eea;
      color: white;
      border-color: #667eea;
    }

    .seat.booked {
      background: #e0e0e0;
      color: #999;
      cursor: not-allowed;
      border-color: #ccc;
    }

    .seat-legend {
      display: flex;
      justify-content: center;
      gap: 30px;
      margin-top: 20px;
      font-size: 12px;
    }

    .legend-item {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .legend-box {
      width: 20px;
      height: 20px;
      border: 2px solid #ddd;
      border-radius: 4px;
    }

    .legend-box.available {
      background: #fff;
      border-color: #ddd;
    }

    .legend-box.selected {
      background: #667eea;
      border-color: #667eea;
    }

    .legend-box.booked {
      background: #e0e0e0;
      border-color: #ccc;
    }

    .booking-summary {
      background: #f9f9f9;
      padding: 20px;
      border-radius: 8px;
      margin-top: 30px;
      border-left: 4px solid #667eea;
    }

    .summary-row {
      display: flex;
      justify-content: space-between;
      margin-bottom: 10px;
      color: #333;
    }

    .summary-row label {
      font-weight: 600;
    }

    .summary-row span {
      font-weight: bold;
      color: #667eea;
    }

    .total {
      border-top: 2px solid #ddd;
      padding-top: 10px;
      margin-top: 10px;
      font-size: 18px;
    }

    .actions {
      display: flex;
      gap: 10px;
      margin-top: 30px;
      justify-content: center;
    }

    .btn.book {
      background: #667eea;
      color: white;
      flex: 1;
      max-width: 200px;
    }

    .btn.book:hover {
      background: #5568d3;
      box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
    }

    .btn.book:disabled {
      background: #ccc;
      cursor: not-allowed;
    }

    .btn.logout {
      background: #f0f0f0;
      color: #333;
      max-width: 150px;
    }

    .btn.logout:hover {
      background: #e0e0e0;
    }

    .message {
      padding: 12px;
      border-radius: 8px;
      margin-bottom: 20px;
      text-align: center;
      font-weight: 500;
    }

    .message.error {
      background: #ffebee;
      color: #c62828;
    }

    .message.success {
      background: #e8f5e9;
      color: #2e7d32;
    }

    @media (max-width: 600px) {
      .container {
        padding: 20px;
      }

      .bus-info {
        grid-template-columns: 1fr;
      }

      .bus-seats {
        grid-template-columns: repeat(3, 1fr);
      }

      .seat {
        width: 50px;
        height: 50px;
        font-size: 11px;
      }
    }
  </style>
</head>
<body>
  <div class="container">
    <!-- ===== LOGIN SECTION ===== -->
    <div class="login-section" id="loginSection">
      <div class="card">
        <div class="brand">
          <div class="logo">CB</div>
          <h1>Welcome back</h1>
        </div>
        <p class="muted">Sign in to continue</p>

        <form id="signinForm">
          <label>Email</label>
          <input type="email" name="email" placeholder="you@example.com" required>
          <label>Password</label>
          <input type="password" name="password" placeholder="••••••••" required>
          <button class="btn primary" type="submit">Sign in</button>
        </form>

        <div class="divider"><span>or</span></div>

        <button id="googleBtn" class="btn google">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="1"></circle>
            <path d="M12 1v6m0 6v6"></path>
            <path d="M4.22 4.22l4.24 4.24m2.12 2.12l4.24 4.24M1 12h6m6 0h6"></path>
            <path d="M4.22 19.78l4.24-4.24m2.12-2.12l4.24-4.24"></path>
          </svg>
          Sign in with Google
        </button>

        <p class="muted small">Don't have an account? <a href="#">Sign up</a></p>
      </div>
    </div>

    <!-- ===== BUS BOOKING SECTION ===== -->
    <div class="bus-section" id="busSection">
      <div class="header">
        <h1>🚌 Campus Bus Booking</h1>
        <div class="user-info">
          <span id="userEmail">User: </span>
          <button class="btn logout" onclick="logoutUser()">Logout</button>
        </div>
      </div>

      <div id="message"></div>

      <div class="bus-info">
        <div>
          <label>Route</label>
          <span>Campus → City Center</span>
        </div>
        <div>
          <label>Departure</label>
          <span>02:00 PM</span>
        </div>
      </div>

      <div class="seating-layout">
        <h3>Select Your Seats</h3>
        <div class="bus-seats" id="busSeats"></div>
        <div class="seat-legend">
          <div class="legend-item">
            <div class="legend-box available"></div>
            <span>Available</span>
          </div>
          <div class="legend-item">
            <div class="legend-box selected"></div>
            <span>Selected</span>
          </div>
          <div class="legend-item">
            <div class="legend-box booked"></div>
            <span>Booked</span>
          </div>
        </div>
      </div>

      <div class="booking-summary">
        <div class="summary-row">
          <label>Selected Seats:</label>
          <span id="selectedSeatsText">None</span>
        </div>
        <div class="summary-row">
          <label>Number of Seats:</label>
          <span id="seatCount">0</span>
        </div>
      </div>

      <div class="actions">
        <button class="btn book" onclick="bookSeats()" id="bookBtn" disabled>Book Now</button>
      </div>
    </div>
  </div>

  <script type="module">
    import { auth, provider } from './firebase.js';
    import { signInWithPopup, onAuthStateChanged, signOut } from 'https://www.gstatic.com/firebasejs/9.22.1/firebase-auth.js';

    // Bus Booking Variables
    const TOTAL_SEATS = 32;
    const SEAT_PRICE = 100;
    let selectedSeats = [];
    let bookedSeats = [2, 5, 8, 12, 15, 18, 20, 24];
    let currentUser = null;

    // Check auth state on page load
    onAuthStateChanged(auth, (user) => {
      if (user) {
        currentUser = user;
        showBusSection(user);
      } else {
        showLoginSection();
      }
    });

    // Show login section
    function showLoginSection() {
      document.getElementById('loginSection').classList.remove('hidden');
      document.getElementById('busSection').classList.remove('active');
    }

    // Show bus section
    function showBusSection(user) {
      document.getElementById('loginSection').classList.add('hidden');
      document.getElementById('busSection').classList.add('active');
      document.getElementById('userEmail').textContent = `Welcome, ${user.email}`;
      generateSeats();
      updateSummary();
    }

    // Google Sign-In Handler
    window.signInWithGoogle = async function() {
      try {
        const result = await signInWithPopup(auth, provider);
        console.log('Firebase sign-in successful:', result.user);
        alert("✅ Login successful! Redirecting to Bus Seat Booking page...");
      } catch (error) {
        console.error('Firebase sign-in error:', error);
        alert("❌ Google Sign-In failed. Please try again.");
      }
    };

    // Generate seat layout
    function generateSeats() {
      const container = document.getElementById('busSeats');
      container.innerHTML = '';
      for (let i = 1; i <= TOTAL_SEATS; i++) {
        const seat = document.createElement('div');
        seat.className = 'seat';
        seat.textContent = i;
        seat.id = `seat-${i}`;

        if (bookedSeats.includes(i)) {
          seat.classList.add('booked');
        } else {
          seat.onclick = () => toggleSeat(i);
        }

        container.appendChild(seat);
      }
    }

    // Toggle seat selection
    window.toggleSeat = function(seatNumber) {
      const seatElement = document.getElementById(`seat-${seatNumber}`);

      if (seatElement.classList.contains('selected')) {
        seatElement.classList.remove('selected');
        selectedSeats = selectedSeats.filter(s => s !== seatNumber);
      } else {
        seatElement.classList.add('selected');
        selectedSeats.push(seatNumber);
      }

      updateSummary();
    };

    // Update booking summary
    function updateSummary() {
      const seatCount = selectedSeats.length;

      document.getElementById('selectedSeatsText').textContent = selectedSeats.length > 0 ? selectedSeats.join(', ') : 'None';
      document.getElementById('seatCount').textContent = seatCount;
      document.getElementById('bookBtn').disabled = seatCount === 0;
    }

    // Book seats
    window.bookSeats = function() {
      if (selectedSeats.length === 0) {
        showMessage('Please select at least one seat', 'error');
        return;
      }

      selectedSeats.forEach(seat => {
        bookedSeats.push(seat);
        document.getElementById(`seat-${seat}`).classList.add('booked');
        document.getElementById(`seat-${seat}`).onclick = null;
      });

      showMessage(`✓ Booking Confirmed! Seats: ${selectedSeats.join(', ')}`, 'success');
      selectedSeats = [];
      updateSummary();
    };

    // Show message
    function showMessage(text, type) {
      const messageDiv = document.getElementById('message');
      messageDiv.textContent = text;
      messageDiv.className = `message ${type}`;
      setTimeout(() => {
        messageDiv.textContent = '';
        messageDiv.className = '';
      }, 3000);
    }

    // Logout function
    window.logoutUser = function() {
      signOut(auth).then(() => {
        showLoginSection();
      }).catch((error) => {
        console.error('Logout error:', error);
      });
    };

    // Attach Google button handler
    const googleBtn = document.getElementById('googleBtn');
    if (googleBtn) {
      googleBtn.addEventListener('click', () => {
        signInWithGoogle();
      });
    }

    // Email form handler
    const signinForm = document.getElementById('signinForm');
    if (signinForm) {
      signinForm.addEventListener('submit', (e) => {
        e.preventDefault();
        const fd = new FormData(e.target);
        const payload = Object.fromEntries(fd.entries());
        console.log('Email sign-in payload:', payload);
      });
    }
  </script>
</body>
</html>
